# Copy to apps/web/.env.local and packages/database/.env

# Local Docker Postgres (docker compose up -d)
DATABASE_URL=postgresql://doora:doora_dev_password@localhost:5433/doora_platform
DIRECT_URL=postgresql://doora:doora_dev_password@localhost:5433/doora_platform

# Or Supabase (production)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

AUTH_SECRET=change-me-run-openssl-rand-hex-32
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

GROQ_API_KEY=
NVIDIA_API_KEY=

# Metered — voice/video calls (https://www.metered.ca)
METERED_API_KEY=
METERED_DOMAIN=your-subdomain.metered.live

REDIS_URL=

# Realtime (Railway in production)
ALLOWED_ORIGINS=http://localhost:3000
REALTIME_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
NEXT_PUBLIC_MQTT_URL=wss://broker.hivemq.com:8884/mqtt

# Dev only — skip login when DB is down (never set in production)
# DEV_SKIP_AUTH=true
# NEXT_PUBLIC_DEV_SKIP_AUTH=true
