# Production environment template
# Copy values into Vercel (web) and Railway (realtime) dashboards — never commit secrets.

# ─── Supabase (new doora-platform project only) ───────────────────────────
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Auth (must match on Vercel + Railway) ────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-hex-32
AUTH_URL=https://app.yourdomain.com
NEXTAUTH_URL=https://app.yourdomain.com

# ─── Doora AI ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
NVIDIA_API_KEY=

# ─── Chat realtime (Railway public URL) ───────────────────────────────────
# Vercel only — browser connects here:
NEXT_PUBLIC_REALTIME_URL=https://your-realtime.up.railway.app
# Railway only — comma-separated if you use preview deploys:
ALLOWED_ORIGINS=https://app.yourdomain.com,https://doora-platform.vercel.app

# ─── Smart room MQTT (optional) ───────────────────────────────────────────
NEXT_PUBLIC_MQTT_URL=wss://broker.hivemq.com:8884/mqtt

# ─── Optional ─────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:...@....upstash.io:6379
